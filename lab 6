import cv2

img = cv2.imread('image.jpg')

(h, w) = img.shape[:2]
center = (w // 2, h // 2)

# Clockwise rotation
M1 = cv2.getRotationMatrix2D(center, -45, 1.0)
rotated1 = cv2.warpAffine(img, M1, (w, h))

# Counter-clockwise rotation
M2 = cv2.getRotationMatrix2D(center, 45, 1.0)
rotated2 = cv2.warpAffine(img, M2, (w, h))

cv2.imshow('Original', img)
cv2.imshow('Clockwise', rotated1)
cv2.imshow('CounterClockwise', rotated2)

cv2.waitKey(0)
cv2.destroyAllWindows()
